# Copy this file to .env and fill in real values. NEVER commit .env itself.

# ── Database ──────────────────────────────────────────────────────────────────
# The app reads DATABASE_URL first, then falls back to POSTGRES_URL.
#
# Local dev — Supabase direct connection (port 5432):
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Production (Vercel) — Supabase transaction pooler (port 6543):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres
#
# Legacy local Postgres (only if not using Supabase):
# POSTGRES_URL=postgres://postgres:postgres@localhost:54322/postgres

# ── App ───────────────────────────────────────────────────────────────────────
# Local dev URL; override in Vercel with your real deployment URL
BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Generate a strong random secret (e.g. `openssl rand -base64 32`)
AUTH_SECRET=replace-with-a-random-secret

# Vercel Cron Jobs — set in Vercel dashboard (min 16 chars). Required for cron to run.
# CRON_SECRET=replace-with-random-secret-for-cron

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Project URL (public, used by Next.js images)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Service role key (secret, server-side only) — get from Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Set EMAIL_PROVIDER=resend to enable real emails; otherwise logs to console
# Contacts are synced to Resend on sign-in/sign-up for Broadcasts
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_replace_with_your_key
EMAIL_FROM=Stay Rental <noreply@yourdomain.com>
# OPS_EMAIL=ops@yourdomain.com

# ── Optional services ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_***
# STRIPE_WEBHOOK_SECRET=whsec_***
